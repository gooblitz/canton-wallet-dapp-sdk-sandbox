VITE_WALLET_RPC_URL=
VITE_WALLET_DOMAIN=
VITE_REGISTRY_DOMAIN=https://sp-lat-dn.cddev.site
# Legacy alias still supported:
# VITE_DEVNET_REGISTRY_DOMAIN=
VITE_REGISTRY_API_KEY=
VITE_REGISTRY_URLS_JSON=
VITE_TOKEN_REGISTRY_URL=/api/registry-proxy
VITE_SCAN_URL=/api/registry-proxy

# Vite dev proxy target for /api/registry-proxy -> /v0/scan-proxy/*
SCAN_PROXY_BACKEND_URL=https://sp-lat-dn.cddev.site
# Optional upstream auth header injected by Vite proxy:
# SCAN_PROXY_UPSTREAM_AUTH=Bearer <token>
